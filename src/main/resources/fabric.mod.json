		"main": [
			"io.github.kuscheltiermafia.EchoCraft3"
		],
		"client": [
			"io.github.kuscheltiermafia.EchoCraft3Client"
		],
		"fabric-datagen": [
			"io.github.kuscheltiermafia.EchoCraft3DataGenerator"
		]
	},
	"mixins": [
		"echocraft.mixins.json",
